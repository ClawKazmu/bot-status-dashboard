{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/",
    "restartPolicy": {
      "type": "ON_FAILURE"
    },
    "environment": {
      "DASHBOARD_UPDATE_TOKEN": "${DASHBOARD_UPDATE_TOKEN}"
    }
  }
}
